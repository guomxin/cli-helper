{
  "id": "agentbridge-interactions",
  "name": "AgentBridge Interactions",
  "description": "Renders trusted AgentBridge credential, field-input, and authorization cards in private OpenClaw conversations.",
  "contracts": {
    "agentToolResultMiddleware": [
      "openclaw"
    ],
    "tools": [
      "agentbridge_identity_status",
      "oa_efficiency_data_approval_prepare",
      "oa_efficiency_data_approve",
      "oa_travel_expense_approval_prepare",
      "oa_travel_expense_approve",
      "oa_weekly_report_acknowledgement_prepare",
      "oa_weekly_report_acknowledge",
      "oa_standard_collaboration_approval_prepare",
      "oa_standard_collaboration_approve",
      "agentbridge_server_profile",
      "oa_template_list",
      "oa_workflow_pending_list",
      "oa_workflow_done_list",
      "oa_workflow_tracked_list",
      "oa_workflow_detail_get",
      "oa_workflow_opinions_list",
      "oa_workflow_revoke_prepare",
      "oa_workflow_revoke",
      "oa_business_trip_prepare",
      "oa_business_trip_save_draft",
      "oa_business_trip_submit_prepare",
      "oa_business_trip_submit",
      "oa_leave_prepare",
      "oa_leave_save_draft",
      "oa_leave_submit_prepare",
      "oa_leave_submit",
      "oa_missed_punch_prepare",
      "oa_missed_punch_save_draft",
      "oa_missed_punch_approval_prepare",
      "oa_missed_punch_approve",
      "oa_meeting_create_prepare",
      "oa_meeting_create",
      "oa_session_status",
      "oa_session_login",
      "agentbridge_interaction_get",
      "agentbridge_interaction_resume",
      "agentbridge_operation_get",
      "agentbridge_operation_list"
    ]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowedCardOrigins": {
        "type": "array",
        "description": "Exact trusted origins allowed for AgentBridge card buttons.",
        "items": {
          "type": "string",
          "pattern": "^https?://[^/]+$"
        },
        "uniqueItems": true,
        "default": []
      },
      "mcpServerName": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "default": "agentbridge"
      },
      "mcpUrl": {
        "type": "string",
        "description": "AgentBridge MCP endpoint used by identity-routed native tools. Configure this separately from mcp.servers so one global Bearer token is never shared across users.",
        "pattern": "^https?://[^/]+/.*$"
      },
      "mcpTimeoutSeconds": {
        "type": "integer",
        "minimum": 1,
        "maximum": 300,
        "default": 150
      },
      "identityBindings": {
        "type": "array",
        "description": "Trusted OpenClaw sender identities mapped to environment-backed AgentBridge MCP tokens.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "channel",
            "senderId",
            "tokenEnv"
          ],
          "properties": {
            "channel": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "senderId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "accountId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            "tokenEnv": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "maxLength": 128
            },
            "label": {
              "type": "string",
              "maxLength": 120
            }
          }
        },
        "uniqueItems": true,
        "default": []
      },
      "autoPoll": {
        "type": "boolean",
        "default": true
      },
      "pollIntervalSeconds": {
        "type": "integer",
        "minimum": 1,
        "maximum": 30,
        "default": 2
      },
      "maxPollSeconds": {
        "type": "integer",
        "minimum": 30,
        "maximum": 1800,
        "default": 1800
      },
      "wakeAgentOnComplete": {
        "type": "boolean",
        "description": "Allow non-sensitive background model wake-ups, including one original-request retry after a successful credential login.",
        "default": true
      }
    }
  }
}
