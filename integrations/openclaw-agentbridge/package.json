{
  "name": "@guomxin/openclaw-agentbridge-interactions",
  "version": "0.2.5",
  "description": "Per-user AgentBridge tools and trusted interaction cards for OpenClaw",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "files": [
    "index.js",
    "lib/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "pack:check": "npm pack --dry-run"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1",
      "minGatewayVersion": ">=2026.7.1"
    },
    "install": {
      "minHostVersion": ">=2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "pluginSdkVersion": "2026.7.1"
    }
  }
